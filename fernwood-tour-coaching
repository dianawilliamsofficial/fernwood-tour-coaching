        '<div style="background:#1B5E20;border-radius:14px;padding:20px 24px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">' +
          '<div style="display:flex;align-items:center;gap:12px;">' +
            '<div style="font-size:24px;">&#127908;</div>' +
            '<div>' +
              '<div style="font-size:14px;font-weight:700;color:white;margin-bottom:3px;">Ready to record your version?</div>' +
              '<div style="font-size:12.5px;color:rgba(255,255,255,0.7);">Show how YOU would run this turn with Jane.</div>' +
            '</div>' +
          '</div>' +
          '<button class="btn btn-green" onclick="goToStep(' + state.currentStep + ' + 1)" style="font-size:15px;padding:14px 28px;background:#2E7D32;">Record My Turn ' + turnNum + ' &rarr;</button>' +
        '</div>' +
      '</div>' +
    '</div>';
}

function renderRecordStep(turnNum, turnKey, taskDesc) {
  var td = state.recordings[turnKey];
  var tdURL = state.recordingURLs[turnKey];
  var isSubmitted = state.submitted[turnKey];
  var coaching = COACHING[turnKey];
  var bulletsHTML = coaching.bullets.map(function(b) { return '<li>' + b + '</li>'; }).join('');

  var recorderHTML = '';
  if (isSubmitted) {
    recorderHTML = '<div class="recorder-box has-video">' +
      (tdURL ? '<div class="video-container"><video class="recorded-video" src="' + tdURL + '" controls></video><div class="video-chip">Turn ' + turnNum + ' \u2014 Submitted &#10003;</div></div>' : '') +
      '<p style="color:#2E7D32;font-weight:600;font-size:14px;margin-top:8px;">&#10003; Submitted \u2014 your manager will review this response.</p>' +
    '</div>';
  } else if (td) {
    recorderHTML = '<div class="recorder-box has-video">' +
      '<div class="video-container"><video class="recorded-video" src="' + tdURL + '" controls></video><div class="video-chip">Take recorded \u2014 ready to submit</div></div>' +
      '<div class="btn-row"><button class="btn btn-outline-green" onclick="retakeVideo(\'' + turnKey + '\')">&#8617; Re-record</button><button class="btn btn-dark" onclick="showSubmitForm(\'' + turnKey + '\', ' + turnNum + ')">Submit This Take &rarr;</button></div>' +
    '</div>';
  } else {
    recorderHTML =
      '<div class="mobile-upload-section" style="background:var(--charcoal-dark);border-radius:14px;padding:28px 24px;text-align:center;margin-bottom:14px;">' +
        '<div style="font-size:40px;margin-bottom:14px;">&#128241;</div>' +
        '<div style="font-family:\'Playfair Display\',serif;font-size:19px;font-weight:700;color:white;margin-bottom:10px;">Film your response on your iPhone</div>' +
        '<p style="font-size:13.5px;color:rgba(255,255,255,0.75);line-height:1.7;margin-bottom:20px;">Open your iPhone Camera app, record your response, save it to Photos, then tap the button below to upload it.</p>' +
        '<label class="btn btn-magenta" style="cursor:pointer;font-size:15px;padding:14px 28px;">&#128193; Upload My Video<input type="file" accept="video/*" capture="user" onchange="handleUpload(event,\'' + turnKey + '\')" style="display:none;"></label>' +
      '</div>' +
      '<div class="desktop-recorder"><div class="recorder-box" id="recBox-' + turnKey + '">' +
      '<div id="cameraPreview-' + turnKey + '" style="display:none;"><div class="video-container"><video id="liveFeed-' + turnKey + '" autoplay muted playsinline style="max-height:260px;"></video><div class="video-chip" id="recLabel-' + turnKey + '">Camera Ready</div></div><div class="timer" id="timer-' + turnKey + '">0:00</div></div>' +
      '<div id="idleState-' + turnKey + '"><div class="rec-icon">&#127909;</div><div class="rec-title">Record Your Response</div><div class="rec-desc">' + taskDesc + '</div></div>' +
      '<div class="btn-row"><button class="btn btn-green" id="startBtn-' + turnKey + '" onclick="startRecording(\'' + turnKey + '\')">&#9679; Start Recording</button><button id="stopBtn-' + turnKey + '" onclick="stopRecording(\'' + turnKey + '\')" style="display:none;background:var(--magenta);color:white;" class="btn">&#9632; Stop &amp; Review</button></div>' +
      '<div style="height:1px;background:var(--border);margin:18px 0;"></div>' +
      '<div style="text-align:center;"><p style="color:var(--mid);font-size:13px;margin-bottom:10px;">Or upload a pre-recorded video</p><label class="btn btn-ghost" style="cursor:pointer;">&#128193; Upload<input type="file" accept="video/*" onchange="handleUpload(event,\'' + turnKey + '\')" style="display:none;"></label></div>' +
    '</div></div>';
  }

  var submitFormHTML = !isSubmitted ? '<div class="submit-form" id="submitForm-' + turnKey + '">' +
    '<h4>Ready to submit Turn ' + turnNum + '?</h4>' +
    '<p>Your video will be uploaded automatically and your manager will be notified.</p>' +
    '<div class="btn-row-right"><button class="btn btn-ghost" onclick="document.getElementById(\'submitForm-' + turnKey + '\').style.display=\'none\'">Cancel</button><button class="btn btn-magenta" id="submitBtn-' + turnKey + '" onclick="submitTurn(\'' + turnKey + '\',' + turnNum + ')">Submit Turn ' + turnNum + ' &rarr;</button></div>' +
  '</div>' : '';

  var nextStepHTML = isSubmitted && turnNum < 3 ?
    '<div style="padding:0 28px 28px;display:flex;justify-content:flex-end;"><button class="btn btn-dark" onclick="goToStep(' + (state.currentStep + 1) + ')">Continue to Turn ' + (turnNum + 1) + ' &rarr;</button></div>' :
    isSubmitted && turnNum === 3 ?
    '<div style="background:var(--charcoal-dark);border-radius:16px;padding:28px 32px;text-align:center;margin:0 28px 28px;"><div style="font-size:40px;margin-bottom:12px;">&#127942;</div><div style="font-family:\'Playfair Display\',serif;font-size:20px;font-weight:700;color:white;margin-bottom:10px;">All Three Turns Complete!</div><div style="font-size:13.5px;color:rgba(255,255,255,0.7);">Taking you to your session summary...</div></div>' : '';

  document.getElementById('stepContainer').innerHTML =
    '<div class="step-card">' +
      '<div class="person-header">' +
        '<div class="person-av staff">&#127908;</div>' +
        '<div class="person-info"><div class="person-name">Your Turn</div><div class="person-role staff">Your Response &middot; Turn ' + turnNum + ' of 3</div></div>' +
        '<div class="step-badge">Record Now</div>' +
      '</div>' +
      '<div class="card-divider"></div>' +
      '<div class="coaching-bullets" style="margin:20px 28px;">' +
        '<div class="coaching-bullets-label">\u2726 Mia\u2019s key points \u2014 keep these visible while you record</div>' +
        '<ul>' + bulletsHTML + '</ul>' +
      '</div>' +
      '<div class="card-divider"></div>' +
      '<div class="recorder-section" style="padding-top:20px;">' +
        '<div class="recorder-header"><div class="recorder-header-icon">&#127909;</div><div class="recorder-header-text">Record your Turn ' + turnNum + ' response</div></div>' +
        (isSubmitted ? '<div class="submitted-banner"><div class="check">&#10003;</div><p>Turn ' + turnNum + ' submitted.<span>Your manager will review this response alongside Jane\'s answer and Mia\'s coaching.</span></p></div>' : '') +
        recorderHTML + submitFormHTML +
      '</div>' +
    '</div>' + nextStepHTML;
}

function startRecording(key) {
  if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) { alert('Camera not available. Use the Upload button.'); return; }
  navigator.mediaDevices.getUserMedia({ video: true, audio: true }).then(function(s) {
    stream = s;
    document.getElementById('idleState-' + key).style.display = 'none';
    document.getElementById('cameraPreview-' + key).style.display = 'block';
    document.getElementById('liveFeed-' + key).srcObject = stream;
    recordedChunks = [];
    var mime = getSupportedMime();
    mediaRecorder = new MediaRecorder(stream, { mimeType: mime });
    mediaRecorder.ondataavailable = function(e) { if (e.data.size > 0) recordedChunks.push(e.data); };
    mediaRecorder.onstop = function() { processRecording(key); };
    mediaRecorder.start();
    document.getElementById('startBtn-' + key).style.display = 'none';
    document.getElementById('stopBtn-' + key).style.display = 'inline-flex';
    document.getElementById('recLabel-' + key).innerHTML = '<span style="color:var(--magenta)">&#9679; RECORDING</span>';
    timerSeconds = 0;
    timerInterval = setInterval(function() {
      timerSeconds++;
      var m = Math.floor(timerSeconds / 60), sec = timerSeconds % 60;
      var el = document.getElementById('timer-' + key);
      if (el) { el.textContent = m + ':' + String(sec).padStart(2,'0'); el.className = 'timer recording-timer'; }
    }, 1000);
  }).catch(function() { alert('Camera access required. Please allow permissions or use the Upload button.'); });
}

function stopRecording(key) {
  if (mediaRecorder && mediaRecorder.state !== 'inactive') mediaRecorder.stop();
  if (stream) { stream.getTracks().forEach(function(t) { t.stop(); }); stream = null; }
  clearInterval(timerInterval);
}

function processRecording(key) {
  var blob = new Blob(recordedChunks, { type: getSupportedMime() });
  state.recordings[key] = blob;
  state.recordingURLs[key] = URL.createObjectURL(blob);
  var turnNum = key === 'turn1' ? 1 : key === 'turn2' ? 2 : 3;
  renderRecordStep(turnNum, key, '');
}

function getSupportedMime() {
  var types = ['video/webm;codecs=vp9,opus','video/webm;codecs=vp8,opus','video/webm','video/mp4'];
  for (var i = 0; i < types.length; i++) { if (MediaRecorder.isTypeSupported(types[i])) return types[i]; }
  return 'video/webm';
}

function retakeVideo(key) {
  if (state.recordingURLs[key]) URL.revokeObjectURL(state.recordingURLs[key]);
  state.recordings[key] = null; state.recordingURLs[key] = null;
  var turnNum = key === 'turn1' ? 1 : key === 'turn2' ? 2 : 3;
  renderRecordStep(turnNum, key, '');
}

function handleUpload(event, key) {
  var file = event.target.files[0];
  if (!file || !file.type.startsWith('video/')) { alert('Please select a video file.'); return; }
  if (file.size > 500 * 1024 * 1024) { alert('File too large. Please use a video under 500MB.'); return; }
  state.recordings[key] = file;
  state.recordingURLs[key] = URL.createObjectURL(file);
  var turnNum = key === 'turn1' ? 1 : key === 'turn2' ? 2 : 3;
  renderRecordStep(turnNum, key, '');
}

function showSubmitForm(key, turnNum) {
  var form = document.getElementById('submitForm-' + key);
  if (form) { form.style.display = 'block'; form.scrollIntoView({ behavior: 'smooth', block: 'start' }); }
}

function submitTurn(key, turnNum) {
  var btn = document.getElementById('submitBtn-' + key);
  if (btn) { btn.disabled = true; btn.textContent = 'Uploading video...'; }

  var blob = state.recordings[key];
  if (!blob) {
    showToast('No video recorded \u2014 please record your response first.');
    if (btn) { btn.disabled = false; btn.textContent = 'Submit Turn ' + turnNum + ' \u2192'; }
    return;
  }

  var ext = (blob.type && blob.type.includes('mp4')) ? 'mp4' : 'webm';
  var fileName = 'Module02_Tour_Turn' + turnNum + '_' + state.name.replace(/\s+/g,'_') + '_' + state.club.replace(/\s+/g,'_') + '_' + new Date().toISOString().slice(0,10) + '.' + ext;

  showToast('\u23F3 Uploading Turn ' + turnNum + ' to Google Drive...');

  var reader = new FileReader();
  reader.onload = function(e) {
    var base64 = e.target.result.split(',')[1];
    var payload = {
      fileName: fileName,
      fileData: base64,
      mimeType: blob.type || 'video/webm',
      staffName: state.name,
      staffClub: state.club,
      staffRole: state.role || '',
      turnNum: String(turnNum),
      assessment: 'The Tour Coaching Session',
      submittedAt: new Date().toLocaleString('en-AU')
    };

    fetch(APPS_SCRIPT_UPLOAD_URL, {
      method: 'POST',
      mode: 'no-cors',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    }).then(function() {
      state.submitted[key] = true;
      lsSave();
      sendNotification(key, turnNum);
      showToast('\u2705 Turn ' + turnNum + ' uploaded to Google Drive!');
      setTimeout(function() {
        renderRecordStep(turnNum, key, '');
        if (state.submitted.turn1 && state.submitted.turn2 && state.submitted.turn3) {
          lsClear();
          setTimeout(showCompletion, 2000);
        }
      }, 800);
    }).catch(function(err) {
      console.error('Upload error:', err);
      showToast('Upload failed \u2014 saving to Downloads instead');
      downloadVideoFallback(key, turnNum, fileName, blob);
      state.submitted[key] = true;
      lsSave();
      sendNotification(key, turnNum);
      setTimeout(function() {
        renderRecordStep(turnNum, key, '');
        if (state.submitted.turn1 && state.submitted.turn2 && state.submitted.turn3) {
          lsClear();
          setTimeout(showCompletion, 2000);
        }
      }, 800);
    });
  };
  reader.onerror = function() {
    showToast('Error reading video \u2014 saving to Downloads instead');
    downloadVideoFallback(key, turnNum, fileName, blob);
  };
  reader.readAsDataURL(blob);
}

function downloadVideoFallback(key, turnNum, fileName, blob) {
  try {
    var url = URL.createObjectURL(blob);
    var a = document.createElement('a'); a.href = url; a.download = fileName;
    document.body.appendChild(a); a.click(); document.body.removeChild(a);
    setTimeout(function() { URL.revokeObjectURL(url); }, 5000);
  } catch(e) { console.error('Download fallback failed:', e); }
}

function sendNotification(key, turnNum) {
  var params = new URLSearchParams();
  params.append('staffName', state.name);
  params.append('staffClub', state.club);
  params.append('staffRole', state.role || '');
  params.append('stageNum', String(turnNum));
  params.append('stageName', 'Turn ' + turnNum + ' \u2014 The Tour');
  params.append('objection', 'Tour Module 02');
  params.append('assessment', 'The Tour Coaching Session');
  params.append('submittedAt', new Date().toLocaleString('en-AU'));
  params.append('driveFolder', DRIVE_UPLOAD_FOLDER_URL);
  fetch(APPS_SCRIPT_URL, {
    method: 'POST', mode: 'no-cors',
    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
    body: params.toString()
  }).catch(function(err) { console.error('Notification error:', err); });
}

function showToast(msg) {
  var toast = document.getElementById('saveToast');
  if (!toast) return;
  toast.textContent = msg; toast.classList.add('show');
  setTimeout(function() { toast.classList.remove('show'); }, 4000);
}

function showCompletion() {
  document.getElementById('completeName').textContent = state.name.split(' ')[0];
  document.getElementById('completeClub').textContent = state.club;
  document.getElementById('completeDate').textContent = new Date().toLocaleDateString('en-AU', { day: 'numeric', month: 'short', year: 'numeric' });
  showScreen('screen-complete');
}

function resetAll() {
  lsClear();
  Object.keys(state.recordingURLs).forEach(function(k) { if (state.recordingURLs[k]) URL.revokeObjectURL(state.recordingURLs[k]); });
  state.recordings = { turn1: null, turn2: null, turn3: null };
  state.recordingURLs = { turn1: null, turn2: null, turn3: null };
  state.submitted = { turn1: false, turn2: false, turn3: false };
  state.currentStep = 0;
  showScreen('screen-session');
  goToStep(0);
}
</script>
</div>

<script>
function checkPassword() {
  var pw = document.getElementById('pwInput').value.trim().toLowerCase();
  var valid = ['fernwood2024', 'coaching', 'tour', 'fernwoodcoaching'];
  if (valid.includes(pw)) {
    document.getElementById('passwordScreen').style.display = 'none';
    document.getElementById('mainContent').style.display = 'block';
    try { sessionStorage.setItem('fw_auth', '1'); } catch(e) {}
  } else {
    document.getElementById('pwError').style.display = 'block';
    document.getElementById('pwInput').value = '';
    document.getElementById('pwInput').focus();
  }
}
try {
  if (sessionStorage.getItem('fw_auth') === '1') {
    document.getElementById('passwordScreen').style.display = 'none';
    document.getElementById('mainContent').style.display = 'block';
  }
} catch(e) {}
</script>
