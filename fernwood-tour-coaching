<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Fernwood — The Tour Coaching</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,900;1,400;1,700&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --charcoal-dark: #2A2A2A;
  --charcoal-mid: #3D3D3D;
  --charcoal-light: #5A5A5A;
  --charcoal-pale: #F0F0F0;
  --magenta: #C8007D;
  --magenta-light: #D93B96;
  --magenta-pale: #FCE8F5;
  --gold: #C9A84C;
  --gold-light: #E0C070;
  --gold-pale: #FAF5E8;
  --cream: #FAFAF8;
  --mid: #555555;
  --light: #999999;
  --border: rgba(42,42,42,0.13);
  --shadow: 0 4px 28px rgba(42,42,42,0.10);
  --shadow-lg: 0 16px 56px rgba(42,42,42,0.15);
  --white: #FFFFFF;
  --purple: #6B3FA0;
  --purple-pale: #F0EAF8;
  --teal: #5A9B9E;
  --teal-pale: #E3EFF0;
  --green: #2E7D32;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: 'DM Sans', sans-serif; background: var(--cream); color: var(--charcoal-dark); min-height: 100vh; }

#passwordScreen { display:flex; flex-direction:column; align-items:center; justify-content:center; min-height:100vh; background:var(--charcoal-dark); padding:32px; }
#passwordScreen .pw-card { background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); border-radius:20px; padding:40px 36px; max-width:420px; width:100%; text-align:center; }
#passwordScreen .pw-logo { width:56px; height:56px; background:var(--magenta); border-radius:50%; display:flex; align-items:center; justify-content:center; font-family:'Playfair Display',serif; font-weight:900; color:white; font-size:24px; margin:0 auto 20px; }
#passwordScreen h2 { font-family:'Playfair Display',serif; font-size:26px; font-weight:700; color:white; margin-bottom:8px; }
#passwordScreen p { color:rgba(255,255,255,0.6); font-size:14px; margin-bottom:28px; line-height:1.6; }
#passwordScreen input { width:100%; padding:14px 18px; border-radius:10px; border:1.5px solid rgba(255,255,255,0.15); background:rgba(255,255,255,0.08); color:white; font-size:16px; font-family:'DM Sans',sans-serif; outline:none; margin-bottom:14px; text-align:center; letter-spacing:3px; }
#passwordScreen input::placeholder { letter-spacing:0; color:rgba(255,255,255,0.3); }
#passwordScreen input:focus { border-color:var(--magenta); }
#passwordScreen .pw-error { color:#FF6B6B; font-size:13px; margin-bottom:12px; display:none; }
#mainContent { display:none; }

.header { background: var(--charcoal-dark); position: sticky; top: 0; z-index: 300; box-shadow: 0 2px 20px rgba(0,0,0,0.22); }
.header-inner { max-width: 900px; margin: 0 auto; padding: 14px 32px; display: flex; align-items: center; justify-content: space-between; }
.logo { display: flex; align-items: center; gap: 12px; }
.logo-mark { width: 36px; height: 36px; background: var(--magenta); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-family: 'Playfair Display', serif; font-weight: 900; color: white; font-size: 17px; }
.logo-text { font-family: 'Playfair Display', serif; color: white; font-size: 16px; font-weight: 600; line-height: 1.2; }
.logo-sub { color: rgba(255,255,255,0.5); font-size: 9.5px; letter-spacing: 1.8px; text-transform: uppercase; }
.header-badge { background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.18); border-radius: 20px; padding: 4px 14px; font-size: 11.5px; color: var(--gold-light); font-weight: 500; }

.hero { background: var(--charcoal-dark); padding: 52px 32px 80px; position: relative; overflow: hidden; }
.hero::before { content: ''; position: absolute; top: -80px; right: -80px; width: 400px; height: 400px; background: radial-gradient(circle, rgba(200,0,125,0.22) 0%, transparent 65%); pointer-events: none; }
.hero::after { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 50px; background: var(--cream); clip-path: ellipse(55% 100% at 50% 100%); }
.hero-inner { max-width: 900px; margin: 0 auto; position: relative; z-index: 1; }
.hero-eyebrow { display: inline-flex; align-items: center; gap: 8px; border: 1px solid rgba(200,0,125,0.45); background: rgba(200,0,125,0.15); border-radius: 3px; padding: 5px 16px; font-size: 10px; letter-spacing: 2.5px; text-transform: uppercase; color: #F5A8D4; margin-bottom: 22px; font-weight: 500; }
.hero h1 { font-family: 'Playfair Display', serif; font-size: clamp(28px, 4.5vw, 48px); font-weight: 900; color: white; line-height: 1.1; margin-bottom: 8px; }
.hero h1 em { color: #F5A8D4; font-style: italic; font-weight: 400; }
.hero-rule { width: 44px; height: 2px; background: var(--magenta); margin: 18px 0; }
.hero-desc { color: rgba(255,255,255,0.6); font-size: 15px; line-height: 1.8; max-width: 600px; font-weight: 300; }

.wrapper { max-width: 900px; margin: 0 auto; padding: 40px 32px 80px; }

.screen { display: none; animation: fadeUp 0.5s ease; }
.screen.active { display: block; }
@keyframes fadeUp { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }

.reg-card { background: white; border-radius: 20px; border: 1px solid var(--border); box-shadow: var(--shadow-lg); overflow: hidden; }
.reg-card-body { padding: 36px; }
.form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 24px; }
@media (max-width: 600px) { .form-grid { grid-template-columns: 1fr; } }
.field { display: flex; flex-direction: column; gap: 7px; }
.field label { font-size: 11.5px; font-weight: 600; letter-spacing: 1px; text-transform: uppercase; color: var(--charcoal-dark); }
.field input, .field select { border: 1.5px solid var(--border); border-radius: 9px; padding: 12px 16px; font-size: 14px; font-family: 'DM Sans', sans-serif; color: var(--charcoal-dark); background: var(--cream); transition: border-color 0.2s; outline: none; }
.field input:focus, .field select:focus { border-color: var(--magenta); background: white; }

.progress-tracker { background: white; border-radius: 16px; border: 1px solid var(--border); padding: 20px 28px; margin-bottom: 28px; box-shadow: var(--shadow); overflow-x: auto; }
.tracker-label { font-size: 11px; letter-spacing: 1.5px; text-transform: uppercase; color: var(--light); font-weight: 600; margin-bottom: 14px; }
.tracker-steps { display: flex; align-items: flex-start; min-width: 480px; }
.tracker-step { display: flex; flex-direction: column; align-items: center; gap: 5px; flex: 1; position: relative; }
.tracker-step:not(:last-child)::after { content: ''; position: absolute; top: 13px; left: 50%; width: 100%; height: 2px; background: var(--border); z-index: 0; }
.tracker-step.done::after { background: var(--magenta); }
.tracker-dot { width: 26px; height: 26px; border-radius: 50%; border: 2px solid var(--border); background: white; display: flex; align-items: center; justify-content: center; font-size: 10px; font-weight: 700; color: var(--light); z-index: 1; transition: all 0.3s; flex-shrink: 0; }
.tracker-step.done .tracker-dot { background: var(--magenta); border-color: var(--magenta); color: white; }
.tracker-step.active .tracker-dot { background: var(--magenta); border-color: var(--magenta); color: white; box-shadow: 0 0 0 4px rgba(200,0,125,0.2); }
.tracker-name { font-size: 8.5px; color: var(--light); text-align: center; font-weight: 500; line-height: 1.3; max-width: 70px; }
.tracker-step.done .tracker-name, .tracker-step.active .tracker-name { color: var(--charcoal-dark); font-weight: 600; }

.step-card { background: white; border-radius: 20px; border: 1px solid var(--border); box-shadow: var(--shadow-lg); overflow: hidden; margin-bottom: 20px; }

.person-header { padding: 20px 28px; display: flex; align-items: center; gap: 16px; }
.person-av { width: 52px; height: 52px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 24px; flex-shrink: 0; }
.person-av.jane { background: linear-gradient(135deg, #FFE4B5, #FFCFA0); }
.person-av.mia { background: linear-gradient(135deg, #FFE4B5, #FFDAA0); }
.person-av.staff { background: linear-gradient(135deg, #E8F4E8, #C8E6C8); }
.person-info { flex: 1; }
.person-name { font-family: 'Playfair Display', serif; font-size: 18px; font-weight: 700; color: var(--charcoal-dark); margin-bottom: 2px; }
.person-role { font-size: 11px; letter-spacing: 1.5px; text-transform: uppercase; font-weight: 600; }
.person-role.jane { color: var(--magenta); }
.person-role.mia { color: var(--gold); }
.person-role.staff { color: #2E7D32; }
.step-badge { background: var(--charcoal-pale); border-radius: 8px; padding: 4px 12px; font-size: 11px; font-weight: 600; color: var(--charcoal-light); }

.card-divider { height: 1px; background: var(--border); margin: 0 28px; }

.video-section { padding: 24px 28px; }
.video-label-row { display: flex; align-items: center; gap: 10px; margin-bottom: 14px; }
.video-label-icon { font-size: 18px; }
.video-label-text { font-size: 12px; font-weight: 600; letter-spacing: 1px; text-transform: uppercase; color: var(--charcoal-light); }

.coaching-bullets { margin: 18px 28px 24px; background: var(--gold-pale); border-radius: 14px; padding: 18px 22px; border-left: 4px solid var(--gold); }
.coaching-bullets-label { font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--gold); font-weight: 700; margin-bottom: 12px; display: flex; align-items: center; gap: 8px; }
.coaching-bullets ul { list-style: none; display: flex; flex-direction: column; gap: 9px; }
.coaching-bullets ul li { display: flex; align-items: flex-start; gap: 10px; font-size: 13.5px; color: var(--charcoal-dark); line-height: 1.6; }
.coaching-bullets ul li::before { content: '\2726'; color: var(--gold); font-size: 10px; flex-shrink: 0; margin-top: 4px; }

.context-box { margin: 0 28px 20px; background: var(--magenta-pale); border-radius: 12px; padding: 16px 20px; border-left: 4px solid var(--magenta); }
.context-box-label { font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--magenta); font-weight: 700; margin-bottom: 8px; }
.context-box p { font-size: 13.5px; color: var(--charcoal-dark); line-height: 1.6; font-style: italic; }

.recorder-section { padding: 0 28px 28px; }
.recorder-header { display: flex; align-items: center; gap: 10px; margin-bottom: 16px; }
.recorder-header-icon { font-size: 18px; }
.recorder-header-text { font-size: 12px; font-weight: 600; letter-spacing: 1px; text-transform: uppercase; color: #2E7D32; }
.recorder-box { border: 2px dashed var(--border); border-radius: 16px; padding: 28px; text-align: center; background: rgba(42,42,42,0.02); transition: all 0.25s; }
.recorder-box.has-video { border-color: #2E7D32; background: #F1F8F1; border-style: solid; }
.rec-icon { font-size: 44px; margin-bottom: 14px; }
.rec-title { font-family: 'Playfair Display', serif; font-size: 19px; font-weight: 700; color: var(--charcoal-dark); margin-bottom: 6px; }
.rec-desc { color: var(--mid); font-size: 13px; line-height: 1.6; margin-bottom: 22px; max-width: 400px; margin-left: auto; margin-right: auto; }
.timer { font-family: 'DM Mono', monospace; font-size: 30px; font-weight: 500; color: var(--charcoal-dark); margin-bottom: 10px; }
.timer.recording-timer { color: var(--magenta); }
.video-container { position: relative; border-radius: 12px; overflow: hidden; background: black; margin-bottom: 14px; }
.recorded-video { width: 100%; display: block; border-radius: 12px; max-height: 320px; object-fit: cover; }
.video-chip { position: absolute; top: 10px; left: 10px; background: rgba(0,0,0,0.65); color: white; font-size: 11px; padding: 3px 10px; border-radius: 20px; font-weight: 600; }

.btn { padding: 13px 28px; border-radius: 10px; font-size: 14px; font-weight: 600; cursor: pointer; border: none; transition: all 0.2s; font-family: 'DM Sans', sans-serif; display: inline-flex; align-items: center; gap: 8px; }
.btn-magenta { background: var(--magenta); color: white; }
.btn-magenta:hover { background: var(--magenta-light); transform: translateY(-1px); }
.btn-dark { background: var(--charcoal-dark); color: white; }
.btn-dark:hover { background: var(--charcoal-mid); transform: translateY(-1px); }
.btn-ghost { background: white; color: var(--charcoal-dark); border: 2px solid var(--border); }
.btn-ghost:hover { border-color: var(--charcoal-dark); }
.btn-green { background: #2E7D32; color: white; }
.btn-green:hover { background: #1B5E20; transform: translateY(-1px); }
.btn-outline-green { background: white; color: #2E7D32; border: 2px solid #2E7D32; }
.btn-outline-green:hover { background: #F1F8F1; }
.btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none !important; }
.btn-row { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; margin-top: 14px; }
.btn-row-right { display: flex; gap: 10px; justify-content: flex-end; flex-wrap: wrap; }

.submitted-banner { background: #F1F8F1; border: 1px solid #2E7D32; border-radius: 12px; padding: 16px 20px; display: flex; align-items: center; gap: 12px; margin-bottom: 16px; }
.submitted-banner .check { width: 34px; height: 34px; background: #2E7D32; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-size: 17px; flex-shrink: 0; }
.submitted-banner p { font-size: 14px; color: var(--charcoal-dark); font-weight: 500; }
.submitted-banner p span { font-weight: 400; color: var(--mid); display: block; font-size: 13px; }

.submit-form { background: var(--charcoal-pale); border-radius: 14px; padding: 20px 22px; margin-top: 14px; display: none; }
.submit-form h4 { font-size: 14px; font-weight: 700; color: var(--charcoal-dark); margin-bottom: 6px; }
.submit-form p { font-size: 13px; color: var(--mid); margin-bottom: 14px; }

.completion-card { background: white; border-radius: 20px; border: 1px solid var(--border); padding: 52px 40px; text-align: center; box-shadow: var(--shadow-lg); }
.completion-card h2 { font-family: 'Playfair Display', serif; font-size: 34px; font-weight: 900; color: var(--charcoal-dark); margin-bottom: 10px; }
.completion-congrats { color: var(--magenta); font-size: 13px; letter-spacing: 2px; text-transform: uppercase; font-weight: 600; margin-bottom: 12px; }
.completion-card > p { color: var(--mid); font-size: 15px; line-height: 1.7; max-width: 480px; margin: 0 auto 28px; }
.completion-meta { display: grid; grid-template-columns: repeat(3,1fr); gap: 16px; margin: 24px auto; max-width: 480px; }
.meta-box { background: var(--charcoal-pale); border-radius: 12px; padding: 16px; }
.meta-label { font-size: 10px; letter-spacing: 1.5px; text-transform: uppercase; color: var(--light); margin-bottom: 4px; }
.meta-val { font-family: 'Playfair Display', serif; font-size: 18px; font-weight: 700; color: var(--charcoal-dark); }
.what-next { background: var(--charcoal-pale); border-radius: 14px; padding: 22px 24px; text-align: left; margin-top: 24px; }
.what-next h4 { font-size: 14px; font-weight: 700; color: var(--charcoal-dark); margin-bottom: 12px; }
.next-item { display: flex; gap: 10px; align-items: flex-start; margin-bottom: 10px; font-size: 13.5px; color: var(--mid); line-height: 1.5; }
.next-item::before { content: '\2713'; color: var(--magenta); font-weight: 700; flex-shrink: 0; }

.mia-instagram { background: linear-gradient(135deg, #fdf6e9 0%, #fcefdf 100%); border-radius: 16px; padding: 22px 26px; margin-top: 28px; display: flex; align-items: center; gap: 18px; border: 1px solid rgba(201,168,76,0.25); }
.mia-instagram-icon { width: 48px; height: 48px; background: linear-gradient(135deg, #FFE4B5, #FFDAA0); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 22px; flex-shrink: 0; }
.mia-instagram-text { flex: 1; text-align: left; }
.mia-instagram-text strong { display: block; font-size: 14px; font-weight: 700; color: var(--charcoal-dark); margin-bottom: 3px; }
.mia-instagram-text span { font-size: 12.5px; color: var(--mid); }
.mia-instagram-handle { background: var(--charcoal-dark); color: white; padding: 9px 16px; border-radius: 20px; font-size: 13px; font-weight: 600; text-decoration: none; transition: background 0.2s; white-space: nowrap; }
.mia-instagram-handle:hover { background: var(--magenta); }
@media (max-width: 500px) {
  .mia-instagram { flex-direction: column; text-align: center; }
  .mia-instagram-text { text-align: center; }
}

.save-toast { position: fixed; bottom: 28px; left: 50%; transform: translateX(-50%) translateY(80px); background: var(--charcoal-dark); color: white; padding: 12px 22px; border-radius: 30px; font-size: 13.5px; font-weight: 600; display: flex; align-items: center; gap: 8px; z-index: 9999; box-shadow: 0 8px 32px rgba(0,0,0,0.3); transition: transform 0.4s cubic-bezier(.4,0,.2,1), opacity 0.4s; opacity: 0; pointer-events: none; white-space: nowrap; }
.save-toast.show { transform: translateX(-50%) translateY(0); opacity: 1; }

html.is-mobile .desktop-recorder { display: none !important; }
html.is-mobile .mobile-upload-section { display: block !important; }
.mobile-upload-section { display: none; }

@media (max-width: 600px) {
  .wrapper { padding: 20px 16px 60px; }
  .person-header { padding: 16px 20px; }
  .video-section, .coaching-bullets, .context-box, .recorder-section { padding-left: 20px; padding-right: 20px; }
  .card-divider { margin: 0 20px; }
  .coaching-bullets { margin: 16px 20px 20px; }
  .context-box { margin: 0 20px 16px; }
  .completion-meta { grid-template-columns: 1fr 1fr; }
}
</style>
<script src="https://fast.wistia.com/player.js" async></script>
<script>
(function() {
  var ua = navigator.userAgent || navigator.vendor || window.opera;
  if (/android/i.test(ua) || (/iPad|iPhone|iPod/.test(ua) && !window.MSStream)) {
    document.documentElement.classList.add('is-mobile');
  }
})();
</script>
</head>
<body>

<div id="passwordScreen">
  <div class="pw-card">
    <div class="pw-logo">F</div>
    <h2>The Tour Coaching Platform</h2>
    <p>This platform is for Fernwood Fitness staff only. Enter your access code to continue.</p>
    <input type="password" id="pwInput" placeholder="Enter access code" onkeydown="if(event.key==='Enter')checkPassword()" />
    <div class="pw-error" id="pwError">Incorrect access code. Please try again.</div>
    <button class="btn btn-magenta" onclick="checkPassword()" style="width:100%;padding:14px;font-size:15px;">Access Training &rarr;</button>
    <p style="margin-top:20px;font-size:12px;color:rgba(255,255,255,0.3);">Contact your manager if you need the access code.</p>
  </div>
</div>

<div id="mainContent">
<header class="header">
  <div class="header-inner">
    <div class="logo">
      <div class="logo-mark">F</div>
      <div>
        <div class="logo-text">Fernwood Fitness</div>
        <div class="logo-sub">The Tour Coaching Platform</div>
      </div>
    </div>
    <div class="header-badge">Module 02 &middot; The Tour</div>
  </div>
</header>

<div class="hero">
  <div class="hero-inner">
    <div class="hero-eyebrow">&#127916; Live Video Coaching &middot; Module 02</div>
    <h1>The<br><em>Tour</em></h1>
    <div class="hero-rule"></div>
    <p class="hero-desc">Master the conversation that turns a prospect into an almost-member. Watch Mia coach. Watch Jane respond. Then record your own version. Three turns &mdash; six minutes &mdash; one personalised tour that connects every facility back to her Getting to Know You.</p>
  </div>
</div>

<div class="wrapper">

  <div class="screen active" id="screen-reg">
    <div class="reg-card">
      <div style="background:var(--charcoal-dark);border-radius:20px 20px 0 0;padding:28px 36px 24px;">
        <div style="font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--magenta);font-weight:700;margin-bottom:14px;">Meet Your Coach</div>
        <div style="background:var(--charcoal-dark);border-radius:14px;text-align:center;margin-bottom:20px;">
          <div style="font-size:48px;margin-bottom:12px;">&#127891;</div>
          <div style="font-family:'Playfair Display',serif;font-size:20px;font-weight:700;color:white;margin-bottom:6px;">Mia's Tour Introduction</div>
          <div style="font-size:13px;color:rgba(255,255,255,0.6);margin-bottom:20px;">Watch before you begin</div>
          <div style="border-radius:12px;overflow:hidden;box-shadow:0 4px 16px rgba(0,0,0,0.3);">
            <div style="max-width:360px;margin:0 auto;border-radius:12px;overflow:hidden;"><script src="https://fast.wistia.com/embed/d076o12k7usljra.js" async type="module"></script><wistia-player media-id="d076o12k7usljra" aspect="0.5625" style="display:block;width:100%;"></wistia-player></div>
          </div>
        </div>
        <div style="height:1px;background:rgba(255,255,255,0.1);margin-bottom:20px;"></div>
        <h2 style="font-family:'Playfair Display',serif;font-size:22px;font-weight:700;color:white;margin-bottom:4px;">Welcome to the Tour Coaching Session</h2>
        <p style="color:rgba(255,255,255,0.6);font-size:13.5px;">A 6-minute guided role play with real video coaching from Mia. Jane continues her journey from Module 01.</p>
      </div>
      <div class="reg-card-body">

        <div style="background:var(--charcoal-pale); border-radius:14px; padding:20px 22px; margin-bottom:24px;">
          <div style="font-size:11px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; color:var(--charcoal-light); margin-bottom:14px;">How this session works &middot; 3 turns</div>
          <div style="display:flex; flex-direction:column; gap:12px;">
            <div style="display:flex; gap:14px; align-items:flex-start;">
              <div style="width:36px;height:36px;background:var(--teal);border-radius:50%;display:flex;align-items:center;justify-content:center;color:white;font-size:15px;font-weight:700;flex-shrink:0;">1</div>
